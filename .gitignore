/executables/

# Ignore all .mcpack files everywhere
*.mcpack

# Ignore all ZIP files except those in the Patches folder
*.zip
!Patches/**/*.zip

# Ignore everything in dist folders except .exe files
dist/*


# Standard Python ignores (optional but useful for this repo)
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.spec
build/
venv/
.env/
.DS_Store
.idea/
.vscode/
